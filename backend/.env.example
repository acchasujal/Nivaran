# Environment Configuration Example for Nivaran Backend

# Application Settings
ENVIRONMENT=production
PORT=8000
APP_BASE_URL=https://nivaran-api.onrender.com
FRONTEND_ORIGIN=https://nivaran-project.vercel.app,http://localhost:5173

# Database Configuration
# SQLite Default (Local Development):
DATABASE_URL=sqlite:///nivaran.db
# PostgreSQL Connection Example (Production Render / Neon):
# DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/nivaran?sslmode=require

# Redis Cache & Rate Limiting Configuration
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_PER_MINUTE=120

# Auth & Security Configuration
JWT_SECRET_KEY=nivaran_super_secret_jwt_key_2026_change_in_production!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=nivaran-auth
JWT_AUDIENCE=nivaran-app

# AI Engine (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Email Gateway (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@nivaran.org

# Action Workflow Settings
ESCALATION_THRESHOLD=3
AGENT5_PDF_FALLBACK=true

# WhatsApp Integration (Twilio)
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

